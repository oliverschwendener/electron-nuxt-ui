{
    "name": "electron-nuxt-ui",
    "description": "Template for developing Electron applications using TypeScript, Vue and Nuxt UI",
    "version": "4.5.2",
    "license": "MIT",
    "author": {
        "email": "oliver.schwendener@proton.me",
        "name": "Oliver Schwendener",
        "url": "https://github.com/oliverschwendener"
    },
    "main": "dist-main/index.js",
    "scripts": {
        "build": "vite build",
        "check": "npm run lint && npm run typecheck && npm run prettier:check && npm run test",
        "dev": "vite",
        "lint": "eslint .",
        "package:publish": "electron-builder --config electron-builder.config.js --publish always",
        "package": "electron-builder --config electron-builder.config.js",
        "prettier:check": "prettier --check -- src/**/*.{ts,vue,css}",
        "prettier:write": "prettier --write -- src/**/*.{ts,vue,css}",
        "test:coverage": "vitest run --coverage",
        "test:watch": "vitest",
        "test": "vitest run",
        "typecheck": "npm run typecheck:main && npm run typecheck:preload && npm run typecheck:renderer",
        "typecheck:main": "tsc -p src/main/tsconfig.json --noEmit",
        "typecheck:preload": "tsc -p src/preload/tsconfig.json --noEmit",
        "typecheck:renderer": "vue-tsc -p src/renderer/tsconfig.json --noEmit"
    },
    "devDependencies": {
        "@eslint/js": "^10.0.1",
        "@types/node": "^25.0.9",
        "@vitejs/plugin-vue": "^6.0.5",
        "@vitest/coverage-v8": "^4.1.2",
        "electron": "^40.0.0",
        "electron-builder": "^26.6.0",
        "eslint": "^10.0.0",
        "globals": "^17.0.0",
        "prettier": "^3.8.0",
        "prettier-plugin-organize-imports": "^4.3.0",
        "typescript": "^5.9.3",
        "typescript-eslint": "^8.53.0",
        "vite": "^8.0.3",
        "vite-plugin-electron": "^0.29.1",
        "vitest": "^4.1.2",
        "vue-tsc": "^3.2.5"
    },
    "dependencies": {
        "@nuxt/ui": "^4.5.1",
        "tailwindcss": "^4.2.1",
        "vue": "^3.5.30",
        "vue-router": "^4.6.4"
    }
}
